@php
$user = auth()->user();
$canCreate = $user->canCreateEvaluations();
$canManageTemplates = $user->canEditEvaluationTemplates();
$statusMap = [
    'pendiente'   => ['Pendiente',   'bg-amber-100 text-amber-700 border-amber-200'],
    'en_progreso' => ['En progreso', 'bg-blue-100 text-blue-700 border-blue-200'],
    'completada'  => ['Completada',  'bg-emerald-100 text-emerald-700 border-emerald-200'],
];
@endphp

<div x-data="{
    tab: '{{ $canCreate && old('template_id') ? 'crear' : 'lista' }}',
    selectedTemplate: null,
    templateAreas: [],
    selectedAreaIds: [],
    allAreas: {{ Js::from($areasForCreate->map(fn($a) => ['id' => $a->id, 'name' => $a->name, 'employees_count' => $a->employees_count])) }},
    templates: {{ Js::from($templates->map(fn($t) => ['id' => $t->id, 'name' => $t->name, 'area_ids' => $t->areas->pluck('id')->toArray(), 'area_names' => $t->areas->pluck('name')->toArray(), 'is_global' => $t->areas->isEmpty()])) }},

    selectTemplate(id) {
        const tpl = this.templates.find(t => t.id === id);
        this.selectedTemplate = tpl;
        if (tpl) {
            this.templateAreas = tpl.is_global
                ? this.allAreas
                : this.allAreas.filter(a => tpl.area_ids.includes(a.id));
        } else {
            this.templateAreas = [];
        }
        this.selectedAreaIds = [];
    },

    toggleArea(areaId) {
        const idx = this.selectedAreaIds.indexOf(areaId);
        if (idx === -1) this.selectedAreaIds.push(areaId);
        else this.selectedAreaIds.splice(idx, 1);
    },

    isAreaSelected(areaId) {
        return this.selectedAreaIds.includes(areaId);
    },

    selectAllAreas() {
        this.selectedAreaIds = this.templateAreas.map(a => a.id);
    },

    deselectAllAreas() {
        this.selectedAreaIds = [];
    },

    get totalEmployees() {
        return this.templateAreas
            .filter(a => this.selectedAreaIds.includes(a.id))
            .reduce((sum, a) => sum + a.employees_count, 0);
    }
}" class="space-y-5">

