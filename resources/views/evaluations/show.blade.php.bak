<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.3/Sortable.min.js" integrity="sha512-AeqHfHHnase2OHMFoVoT5DeRiP4vDMFAtxOY7K9JLTt4S+T1PZYX1gcUwSbMhAiUGmVJBR5L1B3d2gxlS1kA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script>
window.evalData = @json($evalDataPayload);
function evalBuilder() {
    const d = window.evalData;

    return {
        editMode: false,
        saveState: 'idle', // idle | saving | saved
        scores: { ...d.scores },
        totals: { ...d.totals },
        completedCount: 0,
        totalCount: 0,
        progress: 0,
        openSections: {},
        sectionsActive: {},
        addSectionForm: { show: false, type: '', typeLabel: '', name: '' },
        sortable: null,

        init() {
            // Open all sections by default
            document.querySelectorAll('[data-section-id]').forEach(el => {
                const id = parseInt(el.dataset.sectionId);
                this.openSections[id] = true;
                this.sectionsActive[id] = !el.classList.contains('inactive');
            });

            // Set sectionsActive from server
            @foreach($evaluation->template?->sections ?? [] as $s)
            this.sectionsActive[{{ $s->id }}] = {{ $s->is_active ? 'true' : 'false' }};
            @endforeach

            this.recalcProgress();

            // Listen for add-criteria events from inner x-data scopes
            window.addEventListener('add-criteria', e => this.addCriteria(e.detail.sectionId, e.detail.name, e.detail.desc));
        },

        // ── Score functions ──
        scoreActiveClass(v) {
            const map = {1:'bg-rose-500 text-white shadow-rose-200',2:'bg-orange-500 text-white shadow-orange-200',3:'bg-amber-400 text-white shadow-amber-200',4:'bg-blue-500 text-white shadow-blue-200',5:'bg-emerald-500 text-white shadow-emerald-200'};
            return (map[v] || 'bg-slate-500 text-white') + ' shadow-md scale-110';
        },

        setScore(criteriaId, role, value) {
            if (d.isReadOnly) return;
            if (!this.scores[criteriaId]) this.scores[criteriaId] = { auto: null, evaluator: null, comment: '' };

            // Toggle off if same value clicked
            const prev = this.scores[criteriaId][role];
            this.scores[criteriaId][role] = prev === value ? null : value;

            // Update hidden inputs for form fallback
            const hiddenId = role === 'auto' ? `auto-${criteriaId}` : `eval-${criteriaId}`;
            const hiddenEl = document.getElementById(hiddenId);
            if (hiddenEl) hiddenEl.value = this.scores[criteriaId][role] ?? '';

            this.recalcProgress();
            this.autosave(criteriaId, role);
        },

        async autosave(criteriaId, role) {
            this.saveState = 'saving';
            const payload = { _method: undefined };
            const sc = this.scores[criteriaId] || {};
            if (role === 'auto') payload.auto_score = sc.auto;
            else { payload.evaluator_score = sc.evaluator; payload.comment = sc.comment || ''; }

            try {
                const res = await fetch(`${d.routes.saveScore}/${criteriaId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': d.csrf, 'X-Requested-With': 'XMLHttpRequest' },
                    body: JSON.stringify(payload),
                });
                if (res.ok) {
                    const data = await res.json();
                    this.totals.auto      = data.total_auto_score ?? this.totals.auto;
                    this.totals.evaluator = data.total_evaluator_score ?? this.totals.evaluator;
                    this.totals.final     = data.final_score ?? this.totals.final;
                    this.saveState = 'saved';
                    setTimeout(() => { if (this.saveState === 'saved') this.saveState = 'idle'; }, 2000);
                } else {
                    this.saveState = 'idle';
                }
            } catch {
                this.saveState = 'idle';
            }
        },

        recalcProgress() {
            let done = 0, total = 0;
            const role = d.isEmployee ? 'auto' : 'evaluator';
            for (const [id, sc] of Object.entries(this.scores)) {
                total++;
                if (sc[role] !== null && sc[role] !== undefined) done++;
            }
            this.completedCount = done;
            this.totalCount = total;
            this.progress = total > 0 ? Math.round(done / total * 100) : 0;
        },

        // ── Edit mode / Sortable ──
        initSortable() {
            const container = document.getElementById('sections-container');
            if (!container || this.sortable) return;
            this.sortable = Sortable.create(container, {
                handle: '.drag-handle',
                animation: 200,
                ghostClass: 'opacity-30',
                dragClass: 'shadow-2xl rotate-1',
                onEnd: () => this.persistOrder(),
            });
        },

        toggleEditMode() {
            this.editMode = !this.editMode;
            if (this.editMode) {
                this.$nextTick(() => this.initSortable());
            } else if (this.sortable) {
                this.sortable.destroy();
                this.sortable = null;
            }
        },

        persistOrder() {
            const ids = [...document.querySelectorAll('#sections-container [data-section-id]')].map(el => parseInt(el.dataset.sectionId));
            fetch(d.routes.reorder, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': d.csrf, 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ order: ids }),
            });
        },

        // ── Section toggle ──
        async toggleSection(sectionId) {
            const res = await fetch(`${d.routes.toggle}/${sectionId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': d.csrf },
                body: JSON.stringify({}),
            });
            if (res.ok) {
                const data = await res.json();
                this.sectionsActive[sectionId] = data.is_active;
            }
        },

        // ── Add section ──
        promptAddSection(type) {
            const labels = { competencias_org: '🧠 Comp. Organizacionales', competencias_cargo: '💼 Comp. del Cargo', responsabilidades: '✅ Responsabilidades', rango: '📊 Tabla de Rangos' };
            this.addSectionForm = { show: true, type, typeLabel: labels[type] || type, name: '' };
        },

        async submitAddSection() {
            if (!this.addSectionForm.name.trim()) return;
            const res = await fetch(d.routes.addSection, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': d.csrf },
                body: JSON.stringify({ name: this.addSectionForm.name, type: this.addSectionForm.type }),
            });
            if (res.ok) {
                this.addSectionForm.show = false;
                // Reload page to show new section
                window.location.reload();
            }
        },

        // ── Add criteria ──
        async addCriteria(sectionId, name, desc) {
            const res = await fetch(`${d.routes.addCriteria}/${sectionId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': d.csrf },
                body: JSON.stringify({ name, description: desc }),
            });
            if (res.ok) {
                window.location.reload();
            }
        },

        // ── Remove criteria ──
        async removeCriteria(criteriaId, sectionId) {
            if (!confirm('¿Quitar este criterio de la evaluación?')) return;
            const res = await fetch(`${d.routes.rmCriteria}/${criteriaId}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': d.csrf },
            });
            if (res.ok) {
                const row = document.getElementById(`row-${criteriaId}`);
                if (row) {
                    row.style.transition = 'all 0.3s ease';
                    row.style.opacity = '0';
                    row.style.maxHeight = row.offsetHeight + 'px';
                    setTimeout(() => { row.style.maxHeight = '0'; row.style.padding = '0'; }, 50);
                    setTimeout(() => row.remove(), 350);
                }
                delete this.scores[criteriaId];
                this.recalcProgress();
            }
        },
    };
}
</script>
@endpush
