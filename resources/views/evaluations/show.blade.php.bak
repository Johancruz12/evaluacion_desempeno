@extends('layouts.app')
@section('title', 'Evaluación')

@php
    $user        = auth()->user();
    $isEmployee  = $user->isEmpleado() && $evaluation->employee_id === $user->id;
    $isEvaluator = $user->isJefeArea() || $user->isAdmin();
    $isReadOnly  = in_array($evaluation->status, ['completada', 'revisada']);
    $canBuild    = !$isReadOnly && $isEvaluator;
    $responsesMap = $evaluation->responses->keyBy('criteria_id');

    $scaleLabels = [1 => 'Deficiente', 2 => 'Regular', 3 => 'Cumple', 4 => 'Supera', 5 => 'Sobresale'];
    $scaleColors = ['1'=>'rose','2'=>'orange','3'=>'amber','4'=>'blue','5'=>'emerald'];

    $sectionMeta = [
        'competencias_org'   => ['icon'=>'🧠','label'=>'Comp. Organizacionales','from'=>'from-teal-50','border'=>'border-teal-300','badge'=>'bg-teal-100 text-teal-700'],
        'competencias_cargo' => ['icon'=>'💼','label'=>'Comp. del Cargo','from'=>'from-cyan-50','border'=>'border-cyan-300','badge'=>'bg-cyan-100 text-cyan-700'],
        'responsabilidades'  => ['icon'=>'✅','label'=>'Responsabilidades','from'=>'from-amber-50','border'=>'border-amber-300','badge'=>'bg-amber-100 text-amber-700'],
        'rango'              => ['icon'=>'📊','label'=>'Tabla de Rangos','from'=>'from-teal-50','border'=>'border-teal-300','badge'=>'bg-teal-100 text-teal-700'],
    ];

    $completedCount = $responsesMap->filter(function($r) use ($isEmployee) {
        return $isEmployee ? $r->auto_score !== null : $r->evaluator_score !== null;
    })->count();
    $rangoCount = 0;
    foreach ($evaluation->template?->sections ?? [] as $_sec) {
        if ($_sec->type === 'rango') {
            $rangoCount += $_sec->criteria->count();
        }
    }
    $totalCount = $responsesMap->count() - $rangoCount;
    $pct = $totalCount > 0 ? round($completedCount / $totalCount * 100) : 0;

    $scoresJson = [];
    foreach ($responsesMap as $id => $r) {
        $scoresJson[$id] = [
            'auto'      => $r->auto_score      ? (int)$r->auto_score      : null,
            'evaluator' => $r->evaluator_score ? (int)$r->evaluator_score : null,
            'comment'   => $r->comment ?? '',
        ];
    }

    $evalDataPayload = [
        'evalId'      => $evaluation->id,
        'templateId'  => $evaluation->template_id,
        'isEmployee'  => $isEmployee,
        'isEvaluator' => $isEvaluator,
        'isReadOnly'  => $isReadOnly,
        'canBuild'    => $canBuild,
        'csrf'        => csrf_token(),
        'scores'      => $scoresJson,
        'totals'      => [
            'auto'      => (float)($evaluation->total_auto_score ?? 0),
            'evaluator' => (float)($evaluation->total_evaluator_score ?? 0),
            'final'     => (float)($evaluation->final_score ?? 0),
        ],
        'routes' => [
            'reorder'     => route('evaluations.builder.reorder', $evaluation),
            'toggle'      => '/evaluations/'.$evaluation->id.'/builder/toggle',
            'addSection'  => route('evaluations.builder.add-section', $evaluation),
            'addCriteria' => '/evaluations/'.$evaluation->id.'/builder/add-criteria',
            'rmCriteria'  => '/evaluations/'.$evaluation->id.'/builder/criteria',
            'saveScore'   => '/evaluations/'.$evaluation->id.'/score',
        ],
        'statusUrl' => route('evaluations.complete', $evaluation),
        'saveUrl'   => route('evaluations.save-responses', $evaluation),
    ];
@endphp

